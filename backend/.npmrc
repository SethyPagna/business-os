# Node 24 + npm 11 settings
legacy-peer-deps=true
fund=false
audit=false

# Ensure native addons are always built/downloaded for the running Node version.
# Without this, npm may skip the postinstall rebuild and load an incompatible binary.
rebuild-bundle=true

# Use the npm-bundled node-gyp (supports Node 24 headers automatically).
# Do NOT pin an external node-gyp here — let npm manage it.
node-gyp=node_modules/.bin/node-gyp

